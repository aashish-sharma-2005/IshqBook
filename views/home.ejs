<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IshqBook</title>

    <link rel="stylesheet" href="/css/home.css">

    <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>

<body>
<div class="hearts">
    <div class="heart">❤</div>
    <div class="heart a-letter">A</div>
    <div class="heart">❤</div>
    <div class="heart a-letter">A</div>
    <div class="heart">❤</div>
    <div class="heart a-letter">A</div>
    <div class="heart">❤</div>
    <div class="heart a-letter">A</div>
</div>
    <!-- NAVBAR -->
    <%- include("partials/navbar") %>

    <div class="main-container">

        <!-- LEFT -->
        <%- include("partials/leftSidebar") %>

        <!-- FEED -->
        <% if(page==="home") { %>
            <%- include("partials/feed") %>
        <% } else if(page==="friend" ){ %>
            <%- include("friends",{users,currentUserId}) %>
        <% } else if(page==="notification"){ %>
            <%-include('notification',{data}) %>
        <% } else if(page==="profile") { %>
            <%- include("profile",{userInfo,friends,friendCount,isOwnProfile,friendship}) %>
        <% } %> 

        <!-- RIGHT -->
        <%- include("partials/rightSidebar") %>

    </div>

</body>

</html>