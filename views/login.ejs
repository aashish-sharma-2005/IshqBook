<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IshqBook - Login</title>
    <link rel="stylesheet" href="/css/login.css">
</head>

<body>

    <div class="background-shape"></div>
    <div class="background-shape2"></div>

    <div class="container">

        <div class="left">

            <h1>IshqBook ❤️</h1>

            <p>
                Connect with your people, share your moments,
                and spread love with the world.
            </p>

            <div class="quote">
                “जहाँ दिल जुड़े, वहीं IshqBook ❤️”
            </div>

        </div>

        <div class="right">

            <div class="login-box">

                <h2>Welcome Back</h2>

                <form id="loginForm">

                    <div class="input-group"><input type="email" id="email" name="email" placeholder="Enter Email">
                    </div>

                    <div class="input-group password-box">
                        <input type="password" id="password" name="password" placeholder="Enter Password">
                        <span class="show-pass" onclick="togglePassword()">👁️</span>
                    </div>

                    <div class="options">
                        <label><input type="checkbox"> Remember me</label>
                        <a href="/forgot-password">Forgot Password?</a>
                    </div>

                    <button type="button" class="login-btn" onclick="submitLogin()">Login to IshqBook</button>

                </form>

                <p id="errorMsg"></p>

                <div class="divider">
                    OR
                </div>

                <div class="social-login">
                    <button class="social-btn google">Google</button>
                    <button class="social-btn facebook">Facebook</button>
                </div>

                <div class="signup">
                    Don't have an account?
                    <a href="/auth/signup">Create Account</a>
                </div>

            </div>

        </div>

    </div>

    <script>

        const email = document.getElementById("email");
        const password = document.getElementById("password");
        const errorMsg = document.getElementById("errorMsg");

        async function submitLogin() {

            if (email.value.trim() === "" || password.value.trim() === "") {

                errorMsg.innerText = "Please fill all fields ❤️";
                errorMsg.style.color = "red";
                errorMsg.style.textAlign = "center";
                errorMsg.style.marginTop = "15px";
                errorMsg.style.fontWeight = "bold";

                if (email.value.trim() === "") {
                    email.style.border = "2px solid red";
                } else {
                    email.style.border = "none";
                }

                if (password.value.trim() === "") {
                    password.style.border = "2px solid red";
                } else {
                    password.style.border = "none";
                }

                return;

            }

            try {
                const email = document.getElementById("email").value;
                const password = document.getElementById("password").value;
                fetch('/auth/login', {
                    method: "POST",
                    headers: { 'content-type': 'application/json' },
                    body: JSON.stringify({ email, password })
                })
                    .then(res => res.json())
                    .then(data => {
                        if (data.status) {

                            errorMsg.innerText = data.message;
                            errorMsg.style.color = "lightgreen";
                            errorMsg.style.textAlign = "center";
                            errorMsg.style.marginTop = "15px";
                            errorMsg.style.fontWeight = "bold";

                            // redirect after 1 sec
                            setTimeout(() => {
                                window.location.href = "/welcome";
                            }, 1000)

                        } else {

                            errorMsg.innerText = data.message;
                            errorMsg.style.color = "red";
                            errorMsg.style.textAlign = "center";
                            errorMsg.style.marginTop = "15px";
                            errorMsg.style.fontWeight = "bold";

                        }
                    })

            } catch (error) {

                errorMsg.innerText = "Server Error 😢";
                errorMsg.style.color = "red";

            }

        }
        function togglePassword() {

            const password = document.getElementById("password");

            if (password.type === "password") {

                password.type = "text";

            } else {

                password.type = "password";

            }

        }
    </script>

</body>

</html>