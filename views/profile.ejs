<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= userInfo.name %> | IshqBook
    </title>
    <link rel="stylesheet" href="/css/profile.css">
</head>

<body>

    <div class="profile">

        <!-- COVER -->
        <!-- COVER -->
        <div class="cover">

            <img src="<%= userInfo.coverPhoto || '/image/cover.jpeg' %>" class="cover-img">

            <% if(isOwnProfile){ %>
                <div class="camera-btn cover-camera" onclick="toggleMenu('coverMenu')">
                    📷
                </div>

                <div class="img-menu" id="coverMenu">
                    <button onclick="uploadCover()">Upload</button>

                    <% if(userInfo.coverPhoto){ %>
                        <button onclick="deleteCover()">Delete</button>
                        <% } else { %>
                            <button disabled>Delete</button>
                            <% } %>
                </div>
                <% } %>

        </div>

        <div class="profile-header">

            <div class="profile-left">

                <div class="profile-pic-wrapper">

                    <img src="<%= userInfo.profilePic || '/image/profile.png' %>" class="profile-pic">

                    <% if(isOwnProfile){ %>
                        <div class="camera-btn profile-camera" onclick="toggleMenu('profileMenu')">
                            📷
                        </div>

                        <div class="img-menu" id="profileMenu">
                            <button onclick="uploadProfile()">Upload</button>

                            <% if(userInfo.profilePic){ %>
                                <button onclick="deleteProfile()">Delete</button>
                                <% } else { %>
                                    <button disabled>Delete</button>
                                    <% } %>
                        </div>
                        <% } %>

                </div>

                <div class="profile-details">
                    <h2>
                        <%= userInfo.name %>
                    </h2>
                    <p>
                        <%= friendCount %> Friends
                    </p>
                </div>

            </div>

            <div class="profile-right">

                <% if(isOwnProfile){ %>

                    <button class="add">Edit Profile</button>

                    <% } else { %>
                        <% if(!friendship){ %>

                            <button data-id="<%= userInfo._id %>" class="add"
                                onclick="sendrequest('<%= userInfo._id %>')">
                                ➕ Add Friend
                            </button>

                            <% } else if(friendship.status==="pending" ){ %>

                                <% if(friendship.sender.toString()===currentUserId.toString()){ %>

                                    <button data-id="<%= userInfo._id %>" class="requested-btn"
                                        onclick="cancelRequest('<%= userInfo._id %>')">

                                        <span class="default-text">⏳ Requested</span>
                                        <span class="hover-text">Cancel Request</span>

                                    </button>

                                    <% } else if(friendship.receiver.toString()===currentUserId.toString()){ %>

                                        <button class="accept" onclick="acceptrequest('<%= userInfo._id %>')">

                                            ✅ Accept

                                        </button>

                                        <% } %>

                                            <% } else if(friendship.status==="accepted" ){ %>

                                                <button class="friends">
                                                    ✓ Friends
                                                </button>

                                                <button class="msg">
                                                    💬 Message
                                                </button>

                                                <% } %>
                                                    <% } %>


            </div>

        </div>

        <!-- INFO -->
        <div class="card">
            <p><b>Friends:</b>
                <%= friendCount %>
            </p>
        </div>

        <!-- TABS -->
        <div class="tabs">
            <button class="active" onclick="showSection('all', this)">All</button>
            <button onclick="showSection('about', this)">About</button>
            <button onclick="showSection('friends', this)">Friends</button>
            <button onclick="showSection('photos', this)">Photos</button>
            <button onclick="showSection('reels', this)">Reels</button>
        </div>

        <div class="content">

            <div id="all" class="section">
                <h3>All Posts Section</h3>
            </div>

            <div id="about" class="section" style="display:none;">
                <h3>About Section</h3>
            </div>

            <div id="friends" class="section" style="display:none;">
                <h3>Friends List</h3>

                <div>
                    <% friends.forEach(f=> { %>
                        <div onclick="profile('<%= f._id %>')">
                            <img src="<%= f.sender.profilePic || '/image/profile.png' %>">
                            <h3>
                                <%= f.sender.name %>
                            </h3>
                        </div>
                        <% }) %>
                </div>
            </div>

            <div id="photos" class="section" style="display:none;">
                <h3>Photos</h3>
            </div>

            <div id="reels" class="section" style="display:none;">
                <h3>Reels</h3>
            </div>

        </div>

    </div>

    <script>

        function showSection(id, el) {
            document.querySelectorAll('.section').forEach(s => s.style.display = 'none');
            document.getElementById(id).style.display = 'block';

            document.querySelectorAll('.tabs button').forEach(b => b.classList.remove('active'));
            el.classList.add('active');
        }
        async function sendrequest(id) {
            try {
                const res = await fetch(`/home/send-request/${id}`, {
                    method: "POST"
                });

                const data = await res.json();

                if (data.status) {
                    const btn = document.querySelector(`button[data-id="${id}"]`);

                    btn.className = "requested-btn";
                    btn.innerHTML = `
                <span class="default-text">⏳ Requested</span>
                <span class="hover-text">Cancel Request</span>
            `;

                    btn.setAttribute("onclick", `cancelRequest('${id}')`);
                }

            } catch (error) {
                console.log(error);
            }
        }


        async function cancelRequest(id) {
            try {
                const res = await fetch(`/home/cancel-request/${id}`, {
                    method: "DELETE"
                });

                const data = await res.json();

                if (data.status) {
                    const btn = document.querySelector(`button[data-id="${id}"]`);

                    btn.className = "add";
                    btn.innerHTML = "➕ Add Friend";

                    btn.setAttribute("onclick", `sendrequest('${id}')`);
                }

            } catch (error) {
                console.log(error);
            }
        }


        async function acceptrequest(id) {
            try {
                const res = await fetch(`/home/accept-request/${id}`, {
                    method: "PATCH"
                });

                const data = await res.json();

                if (data.status) {

                    // page reload
                    location.reload();

                }

            } catch (error) {
                console.log(error);
            }
        }

        function profile(id) {
            window.location.href = `/user/profile/${id}`;
        }

    </script>

</body>
<script>

    function toggleMenu(id) {

        document.querySelectorAll('.img-menu').forEach(menu => {
            if (menu.id !== id) {
                menu.style.display = 'none';
            }
        });

        const menu = document.getElementById(id);

        menu.style.display =
            menu.style.display === "block"
                ? "none"
                : "block";
    }

    window.onclick = function (e) {

        if (!e.target.closest('.camera-btn') &&
            !e.target.closest('.img-menu')) {

            document.querySelectorAll('.img-menu')
                .forEach(menu => {
                    menu.style.display = 'none';
                });
        }
    }

    /* Upload */

    function uploadCover() {
        alert("Cover Upload");
    }

    function uploadProfile() {
        alert("Profile Upload");
    }

    /* Delete */

    function deleteCover() {
        if (confirm("Delete Cover Photo ?")) {
            // fetch route
        }
    }

    function deleteProfile() {
        if (confirm("Delete Profile Photo ?")) {
            // fetch route
        }
    }

</script>

</html>