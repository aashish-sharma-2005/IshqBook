<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IshqBook Signup</title>
    <link rel="stylesheet" href="/css/signup.css">
</head>

<body>

    <div class="container">

        <div class="left">
            <h1>IshqBook ❤️</h1>

            <p>
                Join your people, create memories,
                and spread love around the world.
            </p>

            <div class="quote">
                “जहाँ दिल जुड़े, वहीं IshqBook 💕”
            </div>
        </div>



        <div class="right">

            <h2>Create Account</h2>

            <p id="message"></p>



            <!-- SIGNUP BOX -->

            <div id="signupBox">

                <div class="inputBox">
                    <input type="text" id="name" placeholder="Enter Full Name">
                </div>

                <div class="inputBox">
                    <input type="text" id="username" placeholder="Enter Username">
                </div>

                <div class="inputBox">
                    <input type="email" id="email" placeholder="Enter Email">
                </div>

                <div class="inputBox">
                    <input type="password" id="password" placeholder="Enter Password">
                </div>

                <div class="inputBox">
                    <input type="password" id="confirmPassword" placeholder="Confirm Password">
                </div>

                <button onclick="sendOTP()">
                    Signup to IshqBook
                </button>

            </div>



            <!-- OTP BOX -->

            <div id="otpBox" style="display:none;">

                <h3>Verify OTP</h3>

                <div class="inputBox">
                    <input type="text" id="otp" placeholder="Enter OTP">
                </div>
                <p id="timer"></p>
                <button onclick="verifyOTP()">
                    Verify OTP
                </button>

            </div>



            <div class="bottom">
                Already have an account?
                <a href="/auth/login">Login</a>
            </div>

        </div>

    </div>



    <script>

        const message = document.getElementById('message')

        const signupBox = document.getElementById('signupBox')

        const otpBox = document.getElementById('otpBox')
        const timer = document.getElementById('timer')
        let countdown
        let tempUserData = {}



        async function sendOTP() {

            const name = document.getElementById('name').value.trim()

            const username = document.getElementById('username').value.trim().toLowerCase()

            const email = document.getElementById('email').value.trim().toLowerCase()

            const password = document.getElementById('password').value

            const confirmPassword = document.getElementById('confirmPassword').value



            if (name.length < 3) {
                message.style.color = 'red'
                message.innerText = 'Name too short'
                return
            }

            if (username.length < 3) {
                message.style.color = 'red'
                message.innerText = 'Username too short'
                return
            }

            if (username.includes(' ')) {
                message.style.color = 'red'
                message.innerText = 'No spaces in username'
                return
            }

            if (password.length < 6) {
                message.style.color = 'red'
                message.innerText = 'Password minimum 6 characters'
                return
            }

            if (password !== confirmPassword) {
                message.style.color = 'red'
                message.innerText = 'Passwords do not match'
                return
            }



            tempUserData = {
                name,
                username,
                email,
                password
            }



            try {

                message.style.color = '#555'
                message.innerText = 'Sending OTP...'



                const response = await fetch('/auth/send-otp', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ email })
                })



                const data = await response.json()



                if (!response.ok) {
                    message.style.color = 'red'
                    message.innerText = data.message
                    return
                }



                signupBox.style.display = 'none'

                otpBox.style.display = 'block'

                message.style.color = 'green'

                message.innerText = 'OTP sent successfully'
                startTimer()
            }

            catch (err) {

                console.log(err)

                message.style.color = 'red'

                message.innerText = 'Something went wrong'

            }

        }




        async function verifyOTP() {

            const otp = document.getElementById('otp').value.trim()



            if (otp.length !== 6) {
                message.style.color = 'red'
                message.innerText = 'Enter valid OTP'
                return
            }



            try {

                message.style.color = '#555'

                message.innerText = 'Verifying OTP...'



                const verifyResponse = await fetch('/auth/verify-otp', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        email: tempUserData.email,
                        otp
                    })
                })



                const verifyData = await verifyResponse.json()



                if (!verifyResponse.ok) {
                    message.style.color = 'red'
                    message.innerText = verifyData.message
                    return
                }



                const signupResponse = await fetch('/auth/signup', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(tempUserData)
                })



                const signupData = await signupResponse.json()



                if (!signupResponse.ok) {
                    message.style.color = 'red'
                    message.innerText = signupData.message
                    return
                }
                
                clearInterval(countdown)
                message.style.color = 'green'

                message.innerText = 'Account created successfully'



                setTimeout(() => {

                    window.location.href = '/auth/login'

                }, 1500)

            }

            catch (err) {

                console.log(err)

                message.style.color = 'red'

                message.innerText = 'Something went wrong'

            }

        }
        function startTimer() {

            let time = 120

            countdown = setInterval(() => {

                let minutes = Math.floor(time / 60)

                let seconds = time % 60

                seconds = seconds < 10 ? '0' + seconds : seconds

                timer.innerText = `OTP expires in ${minutes}:${seconds}`

                time--



                if (time < 0) {

                    clearInterval(countdown)

                    otpBox.style.display = 'none'

                    signupBox.style.display = 'block'

                    message.style.color = 'red'

                    message.innerText = 'OTP Expired'

                    timer.innerText = ''

                }

            }, 1000)

        }
    </script>

</body>

</html>